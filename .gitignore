# ───────────── Entornos virtuales ─────────────
venv/
.venv/
env/

# ───────────── Caches Python / Jupyter ─────────────
**/__pycache__/
*.py[cod]
*.so
.ipynb_checkpoints/

# ───────────── Datos generados por el proyecto ─────────────
internal/

# ───────────── Datasets fuente (pesados, no subir) ─────────────
# Modelos SMPL (.pkl ~117 MB) y JSONs auxiliares
src/dataset/AMASS/smpl_module_project/data/
# Ficheros AMASS originales
src/dataset/AMASS/*.npz
# TNT15 (~405 MB de imágenes segmentadas)
src/dataset/TNT15_V1_0/
# NOMO3D (OBJ + medidas)
src/dataset/NOMO3D/
# Zips del profesor
src/dataset/*.zip
src/dataset/*.pdf

# ───────────── Checkpoints y modelos entrenados ─────────────
*.pt
*.pth
*.ckpt
*.h5

